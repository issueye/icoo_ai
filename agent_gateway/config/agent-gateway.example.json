{
  "host": "127.0.0.1",
  "port": 17889,
  "dataDir": "./.agent_gateway",
  "acp": {
    "enabled": true,
    "command": "npx",
    "args": ["-y", "@openai/codex", "mcp-server"],
    "poolSize": 1
  },
  "managementSettings": {
    "agents": [
      {
        "id": "icoo-ai-acp",
        "name": "Icoo AI",
        "protocol": "acp",
        "description": "Default ACP connector profile.",
        "models": ["gpt-5.4"],
        "enabled": true
      }
    ],
    "mcpServers": [
      {
        "id": "mcp_primary",
        "name": "Primary MCP",
        "command": "node",
        "args": ["./mcp/server.js"],
        "enabled": true
      }
    ],
    "scheduleTasks": [
      {
        "id": "task_sync_hourly",
        "name": "Hourly Sync",
        "spec": "0 * * * *",
        "content": "每小时执行一次知识库同步并发送摘要",
        "enabled": true
      }
    ]
  }
}
